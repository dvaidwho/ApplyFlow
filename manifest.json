{
  "manifest_version": 3,
  "name": "ApplyFlow",
  "version": "1.0",
  "description": "Track job applications and save them to Google Sheets",
  "permissions": [
    "identity",
    "activeTab",
    "scripting",
    "storage"
  ],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_OAUTH_CLIENT_ID",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}